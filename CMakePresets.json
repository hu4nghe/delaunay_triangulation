{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "clangcl-vcpkg-debug",
      "displayName": "clang-cl + vcpkg (Debug)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.tools/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "build_tests": "ON",
        "build_vulkan_viewer": "ON"
      }
    }
  ],
  "testPresets": [
    {
      "name": "test-clangcl-vcpkg-debug",
      "configurePreset": "clangcl-vcpkg-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
